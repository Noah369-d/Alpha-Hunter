    "@vitest/ui": "^1.0.0",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.15.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
